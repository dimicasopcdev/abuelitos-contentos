# ─────────────────────────────────────────────
# Abuelitos Contentos — Variables de entorno
# Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────

# Tu API key de Resend (obtén una gratis en resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# El email remitente (debe estar verificado en Resend)
# Primero puedes usar: onboarding@resend.dev (solo para pruebas)
FROM_EMAIL=hola@abuelitoscontentos.com

# Token secreto para proteger el panel admin (invéntate uno seguro)
ADMIN_TOKEN=cambia_esto_por_algo_muy_secreto_2025

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Dominio permitido para CORS (opcional, * permite todos)
ALLOWED_ORIGIN=https://abuelitoscontentos.com
